# Risk-Neutral-Density-Probabilities — environment template
# Copy this file to .env and fill in real values. Never commit .env.

# Data providers
FMP_API_KEY=your_fmp_api_key_here
MASSIVE_API_KEY=your_polygon_api_key_here

# tastytrade OAuth2 (Personal Grant) — único método que funciona en Render.
# Se obtienen una sola vez en my.tastytrade.com → Manage → API Access:
#   - "OAuth Applications" tab → CLIENT_ID + (Regenerate) CLIENT_SECRET
#   - "Manage OAuth Grants" tab → New Grant con scopes "read openid" → REFRESH_TOKEN
# El refresh_token no expira; el access_token vive 15 min y se renueva solo.
TASTYTRADE_CLIENT_ID=your_tt_oauth_client_id
TASTYTRADE_CLIENT_SECRET=your_tt_oauth_client_secret
TASTYTRADE_REFRESH_TOKEN=your_tt_oauth_refresh_token

# tastytrade legacy (sólo fallback local; tastytrade bloquea las IPs de Render)
TASTYTRADE_LOGIN=your_tt_username
TASTYTRADE_PASSWORD=your_tt_password
TASTYTRADE_REMEMBER_TOKEN=your_tt_remember_token

# LLM (optional, used by Streamlit fundamentals tab)
ANTHROPIC_API_KEY=sk-ant-...

# Stripe (used by api/billing/)
STRIPE_SECRET_KEY=sk_test_or_sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_test_or_pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Auth
JWT_SECRET_KEY=generate_with_python_-c__import_secrets__print_secrets_token_hex_32

# Database
DATABASE_URL=sqlite+aiosqlite:///./rnd.db

# App env
APP_ENV=development
